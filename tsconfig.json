{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "./dist",
    "rootDir": ".",
    "types": ["@types/bun"]
  },
  "include": [".opencode/plugins/emperor/**/*.ts", ".opencode/plugins/commander/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
